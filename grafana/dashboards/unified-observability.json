      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "probe_success{job='blackbox-exporter'}",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "Service Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
