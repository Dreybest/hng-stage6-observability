        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(github_actions_workflow_run_total{conclusion='failure'}[1d])) / sum(increase(github_actions_workflow_run_total[1d]))",
          "legendFormat": "Daily Change Failure Rate"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "vector(0.05)",
          "legendFormat": "SLO Threshold — 5%"
        }
